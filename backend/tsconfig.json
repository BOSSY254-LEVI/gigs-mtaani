{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": "src",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["src"]
}
