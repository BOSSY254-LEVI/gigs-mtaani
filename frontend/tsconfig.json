{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "rootDir": ".",
    "baseUrl": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "types": [],
    "paths": {
      "@/*": ["*"],
      "@gigs/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src"]
}
